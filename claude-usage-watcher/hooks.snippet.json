{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /Users/aaryan/bin/claude_usage_watcher.py record"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /Users/aaryan/bin/claude_usage_watcher.py hit-limit"
          }
        ]
      }
    ]
  }
}
